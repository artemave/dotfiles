#!/usr/bin/env bash

flags=()
if [ -f /.dockerenv ] || [ -f /run/.containerenv ]; then
  flags+=(--no-sandbox)
fi

if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
  exec /usr/bin/google-chrome "${flags[@]}" --ozone-platform=wayland --enable-features=UseOzonePlatform --ozone-platform-hint=auto "$@"
else
  exec /usr/bin/google-chrome "${flags[@]}" "$@"
fi
